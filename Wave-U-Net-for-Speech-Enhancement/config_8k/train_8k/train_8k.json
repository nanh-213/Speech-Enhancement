{
    "seed": 0,
    "description": "train with opus 8k",
    "root_dir": "/content/drive/MyDrive/CompressionAssignment1/Wave-U-Net-for-Speech-Enhancement/Experiments",
    "cudnn_deterministic": false,
    "trainer": {
        "module": "trainer.trainer",
        "main": "Trainer",
        "epochs": 150,
        "save_checkpoint_interval": 10,
        "validation": {
            "interval": 10,
            "find_max": true,
            "custom": {
                "visualize_audio_limit": 20,
                "visualize_waveform_limit": 20,
                "visualize_spectrogram_limit": 20,
                "sample_length": 16384
            }
        }
    },
    "model": {
        "module": "model.unet_basic",
        "main": "Model",
        "args": {}
    },
    "loss_function": {
        "module": "model.loss",
        "main": "mse_loss",
        "args": {}
    },
    "optimizer": {
        "lr": 0.0002,
        "beta1": 0.9,
        "beta2": 0.999
    },
    "train_dataset": {
        "module": "dataset.waveform_dataset",
        "main": "Dataset",
        "args": {
            "dataset": "/content/drive/MyDrive/CompressionAssignment1/Wave-U-Net-for-Speech-Enhancement/train_list_final_8k.txt",
            "limit": null,
            "offset": 0,
            "sample_length": 16384,
            "mode": "train"
        }
    },
    "validation_dataset": {
        "module": "dataset.waveform_dataset",
        "main": "Dataset",
        "args": {
            "dataset": "/content/drive/MyDrive/CompressionAssignment1/Wave-U-Net-for-Speech-Enhancement/val_list_final_8k.txt",
            "limit": 50,
            "offset": 0,
            "mode": "validation"
        }
    },
    "train_dataloader": {
        "batch_size": 4,
        "num_workers": 2,
        "shuffle": true,
        "pin_memory": true
    }
}